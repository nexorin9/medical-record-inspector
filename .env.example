# Environment examples for Medical Record Inspector
# 复制此文件为 .env 并填入实际值

# LLM API 配置（可选 - 用于生成缺陷解释）
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4
LLM_API_BASE=https://api.openai.com/v1

# 嵌入模型配置（可选 - 覆盖 config.yaml 中的设置）
EMBEDDER_MODEL=BAAI/bge-micro-v2

# 模板目录（可选）
TEMPLATE_DIR=templates

# 日志级别
LOG_LEVEL=INFO
