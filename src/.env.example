# API Keys - Fill in your actual keys here
# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=GPT-4

# Tongyi Qianwen (DashScope)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ERNIE Bot (Baidu)
ERNIE_API_KEY=your_ernie_api_key_here
ERNIE_SECRET_KEY=your_ernie_secret_key_here

# Model Configuration
MODEL_NAME=GPT-4
TEMPERATURE=0.3
MAX_TOKENS=4096

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM Provider: openai, dashscope, ernie
LLM_PROVIDER=openai
